# LLM Configuration (default: NVIDIA NIM)
LLM_PROVIDER=nvidia
NVIDIA_API_KEY=your-nvidia-api-key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Alternative LLM providers
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Embeddings (default: NVIDIA nv-embed-v1, 4096 dimensions)
EMBEDDING_PROVIDER=nvidia
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embed-v1
EMBEDDING_DIMENSIONS=4096
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Database
DATABASE_URL=postgresql+psycopg://nova:nova@postgres:5432/nova_support

# Paths
DOCS_PATH=data/raw_docs
TICKET_HISTORY_PATH=data/ticket-history.json
SLA_POLICY_PATH=data/raw_docs/sla-policy.md
LOGS_PATH=logs

# MCP
MCP_SERVER_URL=http://mcp-server:8081/mcp

# Agent
MAX_AGENT_ITERATIONS=8
